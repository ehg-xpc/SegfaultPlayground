{
  "rolloutTag": "rollout/stable",
  "scheduler": {
    "maxParallelTasks": 30,
    "pollIntervalMs": 30000
  },
  "allowedTools": ["Read", "Edit", "Write", "Grep", "Glob", "Agent", "Skill"],
  "allowedCommands": ["git", "az", "pwsh", "powershell", "cmd", "cd", "pushd", "ls", "find", "grep", "echo", "npm", "npx", "node", "tsc", "vitest", "uv", "cat", "head", "tail", "mkdir", "cp", "mv"],
  "worktreePathExtensions": [
    "%USERPROFILE%\\.local\\bin",
    "%USERPROFILE%\\scoop\\shims",
    "%NVM_SYMLINK%",
    "%ProgramFiles%\\Microsoft SDKs\\Azure\\CLI2\\wbin",
    "%DEV_REPO%\\Scripts",
    "%DEV_REPO%\\Tools"
  ],
  "projects": {}
}
