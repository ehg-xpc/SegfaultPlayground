# Set default behavior to automatically normalize line endings.
* text=auto

# Force PowerShell scripts to use CRLF line endings (Windows standard)
*.ps1 text eol=crlf
*.psm1 text eol=crlf
*.psd1 text eol=crlf

# Force batch/cmd scripts to use CRLF line endings
*.cmd text eol=crlf
*.bat text eol=crlf

# Force shell scripts to use LF line endings
*.sh text eol=lf

# Python version files should use LF line endings (Python ecosystem standard)
.python-version text eol=lf

# Windows Terminal settings should use CRLF line endings (Windows application)
terminal.settings.json text eol=crlf

# Mark binary files
*.exe binary
*.dll binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary

# These paths intentionally diverge from the upstream template in forks.
# The 'ours' merge driver keeps the fork version on every merge.
# Run `git config merge.ours.driver true` once per clone (also wired into
# Scripts\Devenv\SetupDevice.ps1).
Scripts/Devenv/RepositoryConfig.json merge=ours
Scripts/Devenv/config.json merge=ours
README.md merge=ours
