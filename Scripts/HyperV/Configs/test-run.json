{
  "_comment": "Example MSI test run config. Pass this to Invoke-MSITestRun.ps1 -ConfigPath.",

  "vmName": "TestVM-W11",

  "guestCredential": {
    "username": "TestVM-W11\\TestUser",
    "passwordSecretEnvVar": "TESTVM_PASSWORD"
  },

  "cleanCheckpointName": "pre-install",

  "postInstallCheckpoint": {
    "enabled": true,
    "name": ""
  },

  "msiPath": "C:\\builds\\latest\\MyProduct.msi",
  "msiInstallArgs": "/quiet /norestart ALLUSERS=1",
  "vmInstallDirectory": "C:\\TestRun",
  "installTimeoutSeconds": 300,

  "testScripts": [
    {
      "hostPath": "C:\\tests\\integration\\Test-Installation.ps1",
      "arguments": {
        "ProductVersion": "2.1.0",
        "InstallDir": "C:\\Program Files\\MyProduct"
      },
      "timeoutSeconds": 300,
      "continueOnFailure": false
    },
    {
      "hostPath": "C:\\tests\\integration\\Test-Functionality.ps1",
      "arguments": {},
      "timeoutSeconds": 600,
      "continueOnFailure": true
    }
  ],

  "logCollection": {
    "enabled": true,
    "lastHours": 2,
    "eventLogs": [
      "Application",
      "System",
      "Microsoft-Windows-Installer/Operational",
      "Setup"
    ],
    "extraPaths": [
      "C:\\ProgramData\\MyProduct\\Logs",
      "C:\\Windows\\Logs\\CBS",
      "C:\\Windows\\Temp\\MSI*.log"
    ]
  },

  "outputDirectory": "C:\\TestResults",
  "readyTimeoutSeconds": 180
}
